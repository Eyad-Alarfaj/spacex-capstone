   ]
  },
  {
   "cell_type": {"cell_type": {"cell_type": {"cell_type": {"cell_type": {"cell_type": {"cell_type": {"cell_type": {"cell_type": {"cell_type": {"cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Model Accuracy Comparison Chart"
   ]
  },
  {
   "cell_type": {"cell_type": {"cell_type": {"cell_type": {"cell_type": {"cell_type": {"cell_type": {"cell_type": {"cell_type": {"cell_type": {"cell_type": {"cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
