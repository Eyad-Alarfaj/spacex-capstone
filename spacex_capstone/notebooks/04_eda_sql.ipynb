 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# IBM Data Science Capstone: SpaceX Falcon 9\n",
    "## Part 4: Exploratory Data Analysis - SQL\n",
    "\n",
    "This notebook uses SQLite to analyze SpaceX launch data with structured SQL queries."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import sqlite3\n",
    "from sqlite3 import connect\n",
    "\n",
    "# Load data\n",
    "df = pd.read_csv('/root/spacex_capstone/data/spacex_launches_processed.csv')\nprint(f'Loaded {len(df)} records')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Create SQLite Database"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Connect to SQLite and create database\n",
    "conn = sqlite3.connect('/root/spacex_capstone/spacex.db')\n",
    "df.to_sql('launches', conn, if_exists='replace', index=False)\n",
    "print('SQLite database created successfully')\n",
    "\n",
    "# Verify table\n",
    "result = pd.read_sql('SELECT COUNT(*) as total_records FROM launches', conn)\n",
    "print(f'Total records in database: {result.iloc[0, 0]}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SQL Query 1: Unique Launch Sites"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "query1 = \"\"\"\n",
    "SELECT DISTINCT Launch_Site, COUNT(*) as launch_count\n",
    "FROM launches\n",
    "GROUP BY Launch_Site\n",
    "ORDER BY launch_count DESC;\n",
    "\"\"\"\n",
    "\n",
    "result1 = pd.read_sql(query1, conn)\n",
    "print('Query 1: Unique Launch Sites and Launch Counts')\n",
    "print(result1)\n",
    "print(f'\\nBusiness Insight: Identifies which launch facilities are used most frequently')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SQL Query 2: Total Payload by Customer"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "query2 = \"\"\"\n",
    "SELECT Customer, COUNT(*) as num_launches, SUM(Payload_Mass_kg) as total_payload_kg\n",
    "FROM launches\n",
    "WHERE Customer != 'Unknown'\n",
    "GROUP BY Customer\n",
    "ORDER BY total_payload_kg DESC\n",
    "LIMIT 15;\n",
    "\"\"\"\n",
    "\n",
    "result2 = pd.read_sql(query2, conn)\n",
    "print('Query 2: Top 15 Customers by Total Payload Mass')\n",
    "print(result2)\n",
    "print(f'\\nBusiness Insight: Shows which customers rely on SpaceX for mass deployment')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SQL Query 3: Average Payload by Booster Version"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "query3 = \"\"\"\n",
    "SELECT Booster, COUNT(*) as launches, \n",
    "       ROUND(AVG(Payload_Mass_kg), 0) as avg_payload_kg,\n",
    "       ROUND(AVG(Class), 2) as success_rate\n",
    "FROM launches\n",
    "GROUP BY Booster\n",
    "ORDER BY avg_payload_kg DESC;\n",
    "\"\"\"\n",
    "\n",
    "result3 = pd.read_sql(query3, conn)\n",
    "print('Query 3: Booster Versions - Capacity and Success')\n",
    "print(result3)\n",
    "print(f'\\nBusiness Insight: Different boosters handle different payload sizes with varying success rates')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SQL Query 4: First Successful Landing"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "query4 = \"\"\"\n",
    "SELECT Flight_Number, Date, Launch_Site, Orbit, Payload_Mass_kg, Customer\n",
    "FROM launches\n",
    "WHERE Class = 1\n",
    "ORDER BY Date ASC\n",
    "LIMIT 1;\n",
    "\"\"\"\n",
    "\n",
    "result4 = pd.read_sql(query4, conn)\n",
    "print('Query 4: First Successful First-Stage Landing')\n",
    "print(result4)\n",
    "print(f'\\nBusiness Insight: Milestone date marking SpaceX\\'s first successful booster recovery')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SQL Query 5: Success Rate by Orbit Type"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "query5 = \"\"\"\n",
    "SELECT Orbit, COUNT(*) as total_launches,\n",
    "       SUM(Class) as successful_landings,\n",
    "       ROUND(100.0 * SUM(Class) / COUNT(*), 1) as success_rate_pct\n",
    "FROM launches\n",
    "GROUP BY Orbit\n",
    "ORDER BY success_rate_pct DESC;\n",
    "\"\"\"\n",
    "\n",
    "result5 = pd.read_sql(query5, conn)\n",
    "print('Query 5: Landing Success Rate by Mission Orbit')\n",
    "print(result5)\n",
    "print(f'\\nBusiness Insight: Shows which mission types (orbits) have highest landing success rates')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SQL Query 6: Year-over-Year Success Trends"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "query6 = \"\"\"\n",
    "SELECT Year, COUNT(*) as total_launches,\n",
    "       SUM(Class) as successful_landings,\n",
    "       ROUND(100.0 * SUM(Class) / COUNT(*), 1) as success_rate_pct\n",
    "FROM launches\n",
    "GROUP BY Year\n",
    "ORDER BY Year ASC;\n",
    "\"\"\"\n",
    "\n",
    "result6 = pd.read_sql(query6, conn)\n",
    "print('Query 6: Year-over-Year Performance')\n",
    "print(result6)\n",
    "print(f'\\nBusiness Insight: Shows continuous improvement in landing success over time')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SQL Query 7: Payload Range Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "query7 = \"\"\"\n",
    "SELECT \n",
    "  CASE \n",
    "    WHEN Payload_Mass_kg < 2000 THEN 'Light (< 2000kg)'\n",
    "    WHEN Payload_Mass_kg < 4000 THEN 'Medium (2000-4000kg)'\n",
    "    WHEN Payload_Mass_kg < 6000 THEN 'Heavy (4000-6000kg)'\n",
    "    ELSE 'Very Heavy (>6000kg)'\n",
    "  END as payload_category,\n",
    "  COUNT(*) as num_launches,\n",
    "  ROUND(AVG(Payload_Mass_kg), 0) as avg_payload_kg,\n",
    "  SUM(Class) as successful_landings,\n",
    "  ROUND(100.0 * SUM(Class) / COUNT(*), 1) as success_rate_pct\n",
    "FROM launches\n",
    "GROUP BY payload_category\n",
    "ORDER BY CAST(SUBSTR(payload_category, 1, 1) as INTEGER);\n",
    "\"\"\"\n",
    "\n",
    "result7 = pd.read_sql(query7, conn)\n",
    "print('Query 7: Success Rate by Payload Weight Category')\n",
    "print(result7)\n",
    "print(f'\\nBusiness Insight: Heavier payloads may affect landing success rates')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SQL Query 8: Launch Site Performance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "query8 = \"\"\"\n",
    "SELECT Launch_Site,\n",
    "       COUNT(*) as total_launches,\n",
    "       SUM(Class) as successful_landings,\n",
    "       ROUND(100.0 * SUM(Class) / COUNT(*), 1) as success_rate_pct,\n",
    "       ROUND(AVG(Payload_Mass_kg), 0) as avg_payload_kg\n",
    "FROM launches\n",
    "GROUP BY Launch_Site\n",
    "ORDER BY success_rate_pct DESC;\n",
    "\"\"\"\n",
    "\n",
    "result8 = pd.read_sql(query8, conn)\n",
    "print('Query 8: Launch Site Performance Analysis')\n",
    "print(result8)\n",
    "print(f'\\nBusiness Insight: Different launch facilities show distinct reliability profiles')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SQL Query 9: Top Performing Booster-Site Combinations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "query9 = \"\"\"\n",
    "SELECT Booster, Launch_Site,\n",
    "       COUNT(*) as launches,\n",
    "       SUM(Class) as successful_landings,\n",
    "       ROUND(100.0 * SUM(Class) / COUNT(*), 1) as success_rate_pct\n",
    "FROM launches\n",
    "WHERE COUNT(*) >= 2\n",
    "GROUP BY Booster, Launch_Site\n",
    "HAVING COUNT(*) >= 2\n",
    "ORDER BY success_rate_pct DESC\n",
    "LIMIT 10;\n",
    "\"\"\"\n",
    "\n",
    "result9 = pd.read_sql(query9, conn)\n",
    "print('Query 9: Top Booster-Site Combinations (min 2 launches)')\n",
    "print(result9)\n",
    "print(f'\\nBusiness Insight: Identifies optimal booster and facility pairings')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SQL Query 10: Failure Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "query10 = \"\"\"\n",
    "SELECT Date, Flight_Number, Launch_Site, Orbit, Payload_Mass_kg, Customer\n",
    "FROM launches\n",
    "WHERE Class = 0\n",
    "ORDER BY Date ASC;\n",
    "\"\"\"\n",
    "\n",
    "result10 = pd.read_sql(query10, conn)\n",
    "print('Query 10: All Failed First-Stage Landing Attempts')\n",
    "print(result10)\n",
    "print(f'\\nBusiness Insight: Analyzing failure cases helps identify risk patterns')\n",
    "print(f'Total Failures: {len(result10)}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Summary and Insights"
   ]
  },
  {
   "cell_type": {"cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Summary and Insights"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('='*70)\n",
    "print('SPACEX SQL ANALYSIS SUMMARY')\n",
    "print('='*70)\n",
    "\n",
    "summary_query = \"\"\"\n",
    "SELECT \n",
    "  COUNT(*) as total_launches,\n",
    "  SUM(Class) as total_successes,\n",
    "  ROUND(100.0 * SUM(Class) / COUNT(*), 1) as overall_success_rate,\n",
    "  COUNT(DISTINCT Launch_Site) as num_sites,\n",
    "  COUNT(DISTINCT Orbit) as num_orbits,\n",
    "  ROUND(AVG(Payload_Mass_kg), 0) as avg_payload_kg\n",
    "FROM launches;\n",
    "\"\"\"\n",
    "\n",
    "summary = pd.read_sql(summary_query, conn)\n",
    "print(summary.to_string(index=False))\n",
    "\n",
    "conn.close()\n",
    "print('\\nDatabase connection closed')"
   ]
  }
