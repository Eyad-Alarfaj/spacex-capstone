   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# IBM Data Science Capstone: SpaceX Falcon 9\n",
    "## Part 5: Interactive Folium Map\n",
    "\n",
    "This notebook creates an interactive map of SpaceX launch sites."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import folium\n",
    "from folium import plugins\n",
    "import numpy as np\n",
    "\n",
    "# Load data\n",
    "df = pd.read_csv('/root/spacex_capstone/data/spacex_launches_processed.csv')\nprint(f'Loaded {len(df)} records')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Define Launch Site Coordinates"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# SpaceX launch site coordinates\n",
    "launch_sites = {\n",
    "    'CCAFS': {'lat': 28.5621, 'lon': -80.5771, 'name': 'Cape Canaveral Air Force Station, Florida'},\n",
    "    'KSC': {'lat': 28.3922, 'lon': -80.6161, 'name': 'Kennedy Space Center, Florida'}\n",
    "}\n",
    "\n",
    "print('Launch Sites Defined:')\n",
    "for site, coords in launch_sites.items():\n",
    "    print(f'  {site}: {coords[\"name\"]} ({coords[\"lat\"]}, {coords[\"lon\"]})')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Calculate Site Statistics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate statistics for each site\n",
    "site_stats = df.groupby('Launch_Site').agg({\n",
    "    'Class': ['count', 'sum'],\n",
    "    'Flight_Number': 'max'\n",
    "}).reset_index()\n",
    "\n",
    "site_stats.columns = ['Launch_Site', 'Total_Launches', 'Successful_Landings', 'Latest_Flight']\n",
    "site_stats['Success_Rate'] = (site_stats['Successful_Landings'] / site_stats['Total_Launches'] * 100).round(1)\n",
    "\n",
    "print('\\nSite Statistics:')\n",
    "print(site_stats)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Create Folium Map"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create base map centered on Florida\n",
    "florida_center = [28.45, -80.65]\n",
    "m = folium.Map(location=florida_center, zoom_start=8, tiles='OpenStreetMap')\n",
    "\n",
    "# Add markers for each launch site\n",
    "for site, coords in launch_sites.items():\n",
    "    site_data = site_stats[site_stats['Launch_Site'] == site]\n",
    "    \n",
    "    if len(site_data) > 0:\n",
    "        total = site_data['Total_Launches'].values[0]\n",
    "        success = site_data['Successful_Landings'].values[0]\n",
    "        success_rate = site_data['Success_Rate'].values[0]\n",
    "        \n",
    "        # Choose color based on success rate\n",
    "        if success_rate >= 80:\n",
    "            color = 'green'\n",
    "        elif success_rate >= 60:\n",
    "            color = 'orange'\n",
    "        else:\n",
    "            color = 'red'\n",
    "        \n",
    "        # Create popup with statistics\n",
    "        popup_text = f\"\"\"\n",
    "        <b>{site}</b><br>\n",
    "        {coords['name']}<br>\n",
    "        Total Launches: {total}<br>\n",
    "        Successful Landings: {success}<br>\n",
    "        Success Rate: {success_rate}%\n",
    "        \"\"\"\n",
    "        \n",
    "        # Add circle marker with size based on launch count\n",
    "        folium.CircleMarker(\n",
    "            location=[coords['lat'], coords['lon']],\n",
    "            radius=np.sqrt(total) * 5,\n",
    "            popup=folium.Popup(popup_text, max_width=300),\n",
    "            color=color,\n",
    "            fill=True,\n",
    "            fillColor=color,\n",
    "            fillOpacity=0.7,\n",
    "            weight=3\n",
    "        ).add_to(m)\n",
    "        \n",
    "        # Add marker for exact location\n",
    "        folium.Marker(\n",
    "            location=[coords['lat'], coords['lon']],\n",
    "            popup=popup_text,\n",
    "            icon=folium.Icon(color=color, icon='info-sign')\n",
    "        ).add_to(m)\n",
    "\n",
    "# Save map\n",
    "map_path = '/root/spacex_capstone/images/spacex_launch_sites_map.html'\n",
    "m.save(map_path)\n",
    "print(f'Folium map saved to {map_path}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Calculate Distances to Geographic Features"
   ]
  },
  {
   "cell_type": {"cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Calculate Distances to Geographic Features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from math import radians, cos, sin, asin, sqrt\n",
    "\n",
    "def haversine_distance(lat1, lon1, lat2, lon2):\n",
    "    \"\"\"Calculate great circle distance between two points in kilometers\"\"\"\n",
    "    lon1, lat1, lon2, lat2 = map(radians, [lon1, lat1, lon2, lat2])\n",
    "    dlon = lon2 - lon1\n",
    "    dlat = lat2 - lat1\n",
    "    a = sin(dlat/2)**2 + cos(lat1) * cos(lat2) * sin(dlon/2)**2\n",
    "    c = 2 * asin(sqrt(a))\n",
    "    r = 6371  # Radius of Earth in km\n",
    "    return c * r\n",
    "\n",
    "# Geographic features coordinates\n",
    "features = {\n",
    "    'Atlantic Coast': {'lat': 28.50, 'lon': -80.00},\n",
    "    'Melbourne': {'lat': 28.0836, 'lon': -80.6081},\n",
    "    'Jacksonville': {'lat': 30.3322, 'lon': -81.6557},\n",
    "    'Miami': {'lat': 25.7617, 'lon': -80.1918}\n",
    "}\n",
    "\n",
    "print('\\nDistance from Launch Sites to Geographic Features:\\n')\nfor site, coords in launch_sites.items():\n",
    "    print(f'{site} ({coords[\"name\"]})')\n",
    "    for feature, feature_coords in features.items():\n",
    "        dist = haversine_distance(coords['lat'], coords['lon'], feature_coords['lat'], feature_coords['lon'])\n",
    "        print(f'  to {feature}: {dist:.1f} km')\n",
    "    print()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Create Enhanced Map with Annotations"
   ]
  },
  {
   "cell_type": {"cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Create Enhanced Map with Annotations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create enhanced map\n",
    "m2 = folium.Map(\n",
    "    location=florida_center, \n",
    "    zoom_start=8, \n",
    "    tiles='CartoDB positron',\n",
    "    prefer_canvas=True\n",
    ")\n",
    "\n",
    "# Add heatmap of success rates\n",
    "for site, coords in launch_sites.items():\n",
    "    site_launches = df[df['Launch_Site'] == site]\n",
    "    success_rate = site_launches['Class'].mean()\n",
    "    \n",
    "    # Create larger circle showing cumulative success count\n",
    "    success_count = site_launches['Class'].sum()\n",
    "    \n",
    "    folium.Circle(\n",
    "        location=[coords['lat'], coords['lon']],\n",
    "        radius=success_count * 500,  # Scale for visibility\n",
    "        popup=f'{site}: {success_count} successful landings',\n",
    "        color='green',\n",
    "        fill=True,\n",
    "        fillColor='green',\n",
    "        fillOpacity=0.3,\n",
    "        weight=2\n",
    "    ).add_to(m2)\n\n",
    "    # Add marker\n",
    "    folium.Marker(\n",
    "        location=[coords['lat'], coords['lon']],\n",
    "        popup=f'<b>{site}</b><br>Success Rate: {success_rate:.1%}<br>Launches: {len(site_launches)}',\n",
    "        icon=folium.Icon(color='blue', icon='rocket')\n",
    "    ).add_to(m2)\n",
    "\n",
    "# Add feature markers\n",
    "for feature, feature_coords in features.items():\n",
    "    folium.Marker(\n",
    "        location=[feature_coords['lat'], feature_coords['lon']],\n",
    "        popup=feature,\n",
    "        icon=folium.Icon(color='gray', icon='info-sign')\n",
    "    ).add_to(m2)\n",
    "\n",
    "# Save enhanced map\n",
    "enhanced_map_path = '/root/spacex_capstone/images/spacex_enhanced_map.html'\n",
    "m2.save(enhanced_map_path)\n",
    "print(f'Enhanced map saved to {enhanced_map_path}')"
   ]
  },
