    "print('\\nMaps Created:')\n",
    "print('1. Basic Folium Map - Shows launch sites with statistics')\n",
    "print('2. Enhanced Map - Shows success counts as circles')\n",
    "print('\\nInteractive Features:')\n",
    "print('- Click markers to see launch site statistics')\n",
    "print('- Circle size/radius indicates launch frequency')\n",
    "print('- Color coding shows success rate (green=high, orange=medium, red=low)')\n",
    "print('\\nGeographic Analysis:')\n",
    "print('- Both sites located in Florida')\n",
    "print('- CCAFS and KSC provide coastal access for Atlantic launches')\n",
    "print('- Proximity to urban centers enables support infrastructure')"
   ]
  }
